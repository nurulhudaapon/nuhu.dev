pub fn GET(ctx: zx.RouteContext) !void {
    const og_type = ctx.request.params.get("path") orelse "labs";
    const og_data = getOgImageData(og_type);

    const og_template = OgTemplate(ctx.arena, og_data);
    var aw = std.Io.Writer.Allocating.init(ctx.arena);

    try og_template.render(&aw.writer, .{});
    const svg_text = aw.written();
    const png = try lunasvg.svgToPngAlloc(ctx.arena, svg_text, 1200, 630, 0xffffffff);

    ctx.response.text(png);
    ctx.response.setContentType(.@"image/png");
}


fn getOgImageData(path: []const u8) OgTemplateProps {
    for (og_images) |og_image| {
        if (std.mem.eql(u8, og_image.path, path)) {
            return og_image;
        }
    }
    return default_og_image;
}

const default_og_image: OgTemplateProps = .{
    .path = "labs",
    .title = "nuhu.dev",
    .subtitle = "A studio for focused products.",
};
const og_images = [_]OgTemplateProps{
    default_og_image,
    .{
        .path = "byakaron",
        .title = "Byakaron",
        .subtitle = "The last Bangla keyboard you'll ever need.",
    },
};

fn staticParams(ctx: *zx.StaticContext) !void {
    for (og_images) |og_image| {
        try ctx.params.add(.{ .path = og_image.path });
    }
}

pub const options = zx.RouteOptions{
    .static = staticParams,
};


const OgTemplate = @import("template.zx").OgTemplate;
const OgTemplateProps = @import("template.zx").OgTemplateProps;

const lunasvg = @import("lunasvg");
const zx = @import("zx");
const std = @import("std");
